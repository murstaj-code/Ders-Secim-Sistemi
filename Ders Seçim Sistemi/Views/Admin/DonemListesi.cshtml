@model IEnumerable<Ders_Seçim_Sistemi.Models.Entities.Donem>

@{
    ViewBag.Title = "Dönem Listesi";
}

<div class="container">
    <h2>Dönem Listesi</h2>
    @Html.ActionLink("Yeni Dönem Ekle", "DonemEkle", "Admin", null, new { @class = "btn btn-primary" })
    <hr />
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Dönem Adı</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>Aktif</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var donem in Model)
            {
                <tr>
                    <td>@donem.Id</td>
                    <td>@donem.Ad</td>
                    <td>@donem.BaslangicTarihi.ToShortDateString()</td>
                    <td>@donem.BitisTarihi.ToShortDateString()</td>
                    <td>@(donem.AktifMi ? "Evet" : "Hayır")</td>
                    <td>
                        @Html.ActionLink("Aktif/Pasif", "DonemAktifDegistir", "Admin", new { id = donem.Id }, new { @class = "btn btn-warning btn-sm" })
                        @Html.ActionLink("Sil", "DonemSil", "Admin", new { id = donem.Id }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <hr />
    @Html.ActionLink("Admin Paneline Dön", "Index", "Admin", null, new { @class = "btn btn-default" })
</div>

