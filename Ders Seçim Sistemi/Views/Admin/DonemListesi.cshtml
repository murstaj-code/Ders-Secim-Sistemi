@model IEnumerable<Ders_Seçim_Sistemi.Models.Entities.Donem>

@{
    ViewBag.Title = "Dönem İşlemleri";
}

<style>

    body {
        background: radial-gradient(circle at top left, #dbeafe, #f1f5f9 40%), radial-gradient(circle at bottom right, #bfdbfe, #f8fafc 35%);
        min-height: 100vh;
    }

    /* PAGE TITLE */

    .page-title {
        font-size: 42px;
        font-weight: 800;
        color: #0F172A;
        margin-bottom: 24px;
        animation: fadeIn 0.7s ease;
    }

    /* TOP BUTTON */

    .top-btn {
        display: inline-block;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#0F172A,#1E3A8A);
        transition: 0.3s;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(15,23,42,0.18);
    }

        .top-btn:hover {
            text-decoration: none;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 18px rgba(59,130,246,0.35), 0 14px 28px rgba(15,23,42,0.22);
            background: linear-gradient(135deg,#172554,#2563EB);
        }

    /* TABLE CARD */

    .table-card {
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(14px);
        border-radius: 28px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.5);
        box-shadow: 0 10px 40px rgba(15,23,42,0.10);
        animation: fadeIn 0.7s ease;
    }

    /* TABLE */

    .modern-table {
        width: 100%;
        margin: 0;
        border-collapse: collapse;
    }

        .modern-table thead {
            background: linear-gradient(135deg,#0F172A,#172554);
            color: white;
        }

        .modern-table th {
            padding: 18px;
            font-size: 15px;
            font-weight: 700;
        }

        .modern-table td {
            padding: 18px;
            color: #0F172A;
            border-top: 1px solid rgba(203,213,225,0.7);
        }

        .modern-table tbody tr {
            transition: 0.25s;
        }

            .modern-table tbody tr:hover {
                background: rgba(219,234,254,0.35);
                transform: scale(1.002);
            }

    /* ACTIVE BADGE */

    .badge-aktif {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        background: rgba(34,197,94,0.15);
        color: #166534;
    }

    .badge-pasif {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        background: rgba(239,68,68,0.15);
        color: #991B1B;
    }

    /* ACTION BUTTONS */

    .btn-aktif {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#0F172A,#1E3A8A);
        transition: 0.3s;
        margin-right: 6px;
    }

        .btn-aktif:hover {
            color: white;
            text-decoration: none;
            box-shadow: 0 0 16px rgba(59,130,246,0.35);
        }

    .btn-pasif {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#7F1D1D,#DC2626);
        transition: 0.3s;
        margin-right: 6px;
    }

        .btn-pasif:hover {
            color: white;
            text-decoration: none;
            box-shadow: 0 0 16px rgba(239,68,68,0.35);
        }

    .btn-sil {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#7F1D1D,#DC2626);
        transition: 0.3s;
    }

        .btn-sil:hover {
            color: white;
            text-decoration: none;
            box-shadow: 0 0 16px rgba(239,68,68,0.35);
        }

    /* BACK BUTTON */

    .btn-back {
        display: inline-block;
        margin-top: 24px;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#7F1D1D,#DC2626);
        transition: 0.3s;
    }

        .btn-back:hover {
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
            box-shadow: 0 0 18px rgba(239,68,68,0.35);
        }

    /* ANIMATION */

    @@keyframes fadeIn {

        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container" style="margin-top:40px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 class="page-title" style="margin: 0;">Dönem İşlemleri</h2>
        @Html.ActionLink("Admin Paneline Dön", "Index", "Admin", null, new { @class = "btn-back" })
    </div>


    @Html.ActionLink(
        "Yeni Dönem Ekle",
        "DonemEkle",
        "Admin",
        null,
        new { @class = "top-btn" })

    <div class="table-card">

        <table class="modern-table">

            <thead>

                <tr>

                    <th>Id</th>

                    <th>Dönem Adı</th>

                    <th>Başlangıç</th>

                    <th>Bitiş</th>

                    <th>Durum</th>

                    <th>İşlemler</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var donem in Model)
                {
                    <tr>

                        <td>@donem.Id</td>

                        <td>@donem.Ad</td>

                        <td>@donem.BaslangicTarihi.ToShortDateString()</td>

                        <td>@donem.BitisTarihi.ToShortDateString()</td>

                        <td>

                            @if (donem.AktifMi)
                            {
                                <span class="badge-aktif">
                                    Aktif
                                </span>
                            }
                            else
                            {
                                <span class="badge-pasif">
                                    Pasif
                                </span>
                            }

                        </td>

                        <td>

                            @Html.ActionLink(
                                donem.AktifMi ? "Pasifleştir" : "Aktifleştir",
                                "DonemAktifDegistir",
                                "Admin",
                                new { id = donem.Id },
                                new
                                {
                                    @class = donem.AktifMi
                                        ? "btn-pasif"
                                        : "btn-aktif"
                                })

                            @Html.ActionLink(
                                "Sil",
                                "DonemSil",
                                "Admin",
                                new { id = donem.Id },
                                new { @class = "btn-sil" })

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>