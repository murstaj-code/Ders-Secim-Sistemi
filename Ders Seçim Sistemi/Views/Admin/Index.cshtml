@{
    ViewBag.Title = "Admin Paneli";
}

<style>

    body {
        background: radial-gradient(circle at top left, #dbeafe, #f1f5f9 40%), radial-gradient(circle at bottom right, #bfdbfe, #f8fafc 35%);
        min-height: 100vh;
    }

    /* HEADER */

    .admin-header {
        background: linear-gradient(135deg,#0F172A,#172554);
        color: white;
        padding: 22px 28px;
        border-radius: 24px;
        margin-bottom: 28px;
        box-shadow: 0 10px 35px rgba(15,23,42,0.15);
        animation: fadeIn 0.7s ease;
    }

        .admin-header h2 {
            margin: 0;
            font-weight: 800;
            font-size: 36px;
        }

    /* GRID */

    .admin-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
        gap: 24px;
        margin-bottom: 30px;
    }

    /* CARD */

    .admin-card {
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.5);
        border-radius: 24px;
        padding: 24px;
        transition: 0.3s;
        box-shadow: 0 10px 35px rgba(15,23,42,0.08);
        animation: fadeIn 0.7s ease;
    }

        .admin-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 25px rgba(59,130,246,0.15), 0 18px 40px rgba(15,23,42,0.12);
        }

    /* TITLE */

    .card-title {
        color: #0F172A;
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    /* BUTTON */

    .yonet-btn {
        display: inline-block;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        font-size: 15px;
        background: linear-gradient(135deg,#0F172A,#1E3A8A);
        transition: 0.3s;
        box-shadow: 0 8px 20px rgba(15,23,42,0.18);
    }

        .yonet-btn:hover {
            text-decoration: none;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 18px rgba(59,130,246,0.35), 0 14px 28px rgba(15,23,42,0.22);
            background: linear-gradient(135deg,#172554,#2563EB);
        }

    /* LOGOUT */

    .logout-btn {
        display: inline-block;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        color: white;
        font-weight: 700;
        background: linear-gradient(135deg,#7F1D1D,#DC2626);
        transition: 0.3s;
    }

        .logout-btn:hover {
            text-decoration: none;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 18px rgba(239,68,68,0.35);
        }

    /* ANIMATION */

    @@keyframes fadeIn {

        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container" style="margin-top:40px;">

    <div class="admin-header">

        <h2>
            Hoş geldiniz, @Session["KullaniciAd"]
        </h2>

    </div>

    <div class="admin-grid">

        <div class="admin-card">

            <div class="card-title">
                Öğrenci İşlemleri
            </div>

            @Html.ActionLink(
                "Öğrencileri Yönet",
                "OgrenciListesi",
                "Admin",
                null,
                new { @class = "yonet-btn" })

        </div>

        <div class="admin-card">

            <div class="card-title">
                Ders İşlemleri
            </div>

            @Html.ActionLink(
                "Dersleri Yönet",
                "DersListesi",
                "Admin",
                null,
                new { @class = "yonet-btn" })

        </div>

        <div class="admin-card">

            <div class="card-title">
                Dönem İşlemleri
            </div>

            @Html.ActionLink(
                "Dönemleri Yönet",
                "DonemListesi",
                "Admin",
                null,
                new { @class = "yonet-btn" })

        </div>

        <div class="admin-card">

            <div class="card-title">
                Danışman İşlemleri
            </div>

            @Html.ActionLink(
                "Danışmanları Yönet",
                "DanismanListesi",
                "Admin",
                null,
                new { @class = "yonet-btn" })

        </div>

        <div class="admin-card">

            <div class="card-title">
                Bölüm İşlemleri
            </div>

            @Html.ActionLink(
                "Bölümleri Yönet",
                "BolumListesi",
                "Admin",
                null,
                new { @class = "yonet-btn" })

        </div>

    </div>

    @Html.ActionLink(
        "Çıkış Yap",
        "Logout",
        "Account",
        null,
        new { @class = "logout-btn" })

</div>