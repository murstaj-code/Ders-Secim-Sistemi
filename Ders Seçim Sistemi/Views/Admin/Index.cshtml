@{
    ViewBag.Title = "Admin Paneli";
}

<div class="container">
    <h2>Hoş geldiniz, @Session["KullaniciAd"]</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <div class="panel panel-primary">
                <div class="panel-heading">Öğrenci İşlemleri</div>
                <div class="panel-body">
                    @Html.ActionLink("Öğrencileri Yönet", "Index", "Ogrenci", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel panel-success">
                <div class="panel-heading">Ders İşlemleri</div>
                <div class="panel-body">
                    @Html.ActionLink("Dersleri Yönet", "Index", "Ders", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel panel-warning">
                <div class="panel-heading">Dönem İşlemleri</div>
                <div class="panel-body">
                    @Html.ActionLink("Dönemleri Yönet", "Index", "Donem", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    </div>
    <hr />
    @Html.ActionLink("Çıkış Yap", "Logout", "Account", null, new { @class = "btn btn-danger" })
</div>

