@model IEnumerable<Ders_Seçim_Sistemi.Models.Entities.Ders>

@{
    ViewBag.Title = "Ders Listesi";
}

<div class="container">
    <h2>Ders İşlemleri</h2>
    @Html.ActionLink("Yeni Ders Ekle", "DersEkle", "Admin", null, new { @class = "btn", style = "background-color: #0F172A; color: white; margin-top: 10px; margin-bottom: 10px;" })
    <table class="table" style="border: 2px solid #0F172A; border-collapse: collapse;">
        <thead>
        <thead style="background-color: #0F172A; color: white;">
            <tr>
                <th>Id</th>
                <th>Ders Adı</th>
                <th>Kredi</th>
                <th>Kontenjan</th>
                <th>Bölüm</th>
                <th>Gün</th>
                <th>Saat</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ders in Model)
            {
                <tr>
                    <td>@ders.Id</td>
                    <td>@ders.Ad</td>
                    <td>@ders.Kredi</td>
                    <td>@ders.Kontenjan</td>
                    <td>@(ders.Bolum != null ? ders.Bolum.Ad : "-")</td>
                    <td>@ders.Gun</td>
                    <td>@ders.SaatBaslangic - @ders.SaatBitis</td>
                    <td>
                        @Html.ActionLink("Güncelle", "DersGuncelle", "Admin", new { id = ders.Id }, new { @class = "btn btn-sm", style = "background-color: #0F172A; color: white;" })
                        @Html.ActionLink("Sil", "DersSil", "Admin", new { id = ders.Id }, new { @class = "btn btn-sm", style = "background-color: #7F1D1D; color: white;" })
                    </td>
                </tr>
            }

        </tbody>
    </table>
    @Html.ActionLink("Admin Paneline Dön", "Index", "Admin", null, new { @class = "btn btn-default", style = "background-color: #7F1D1D; color: white;" })
</div>