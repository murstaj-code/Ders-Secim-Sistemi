@model Ders_Seçim_Sistemi.Models.Entities.Danisman

@{
    ViewBag.Title = "Danışman Güncelle";
}

<style>
    .form-kutu {
        border: 4px solid #0F172A;
        border-radius: 12px;
        padding: 30px;
        width: 450px;
        margin: 40px auto;
        background-color: #f7f7f0;
    }

        .form-kutu .form-control {
            border: 2px solid #0F172A;
        }

            .form-kutu .form-control:focus {
                border: 2px solid #0F172A;
                box-shadow: none;
            }
</style>

<div class="container">
    <div class="form-kutu">
        <h2 style="text-align:center;">Danışman Güncelle</h2>
        @using (Html.BeginForm("DanismanGuncelle", "Admin", new { id = Model.Id }, FormMethod.Post))
        {
            <div class="form-group">
                <label>Ad</label>
                <input type="text" name="Ad" class="form-control" value="@Model.Kullanici.Ad" />
            </div>
            <div class="form-group">
                <label>Soyad</label>
                <input type="text" name="Soyad" class="form-control" value="@Model.Kullanici.Soyad" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="Email" class="form-control" value="@Model.Kullanici.Email" />
            </div>
            <div class="form-group">
                <label>Parola (zorunlu)</label>
                <input type="password" name="Parola" class="form-control" />
            </div>
            <div class="form-group">
                <label>Bölüm</label>
                @Html.DropDownList("BolumId", ViewBag.BolumId as SelectList, "Seçiniz", new { @class = "form-control" })
            </div>
            <button type="submit" class="btn" style="background-color:#0F172A; color:white; margin-top:10px;">Güncelle</button>
            @Html.ActionLink("İptal", "DanismanListesi", "Admin", null, new { @class = "btn", style = "background-color:#7F1D1D;color:white;margin-top:10px;" })
        }
        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger">@TempData["Hata"]</div>
        }
    </div>
</div>  