@model Ders_Seçim_Sistemi.Models.Entities.Donem

@{
    ViewBag.Title = "Dönem Ekle";
}

<style>
    .form-kutu {
        border: 4px solid #0F172A;
        border-radius: 12px;
        padding: 30px;
        width: 450px;
        margin: 40px auto;
        background-color: #f7f7f0;
    }

        .form-kutu .form-control {
            border: 2px solid #0F172A;
        }

            .form-kutu .form-control:focus {
                border: 2px solid #0F172A;
                box-shadow: none;
            }
</style>

<div class="container">
    <div class="form-kutu">
        <h2 style="text-align:center;">Yeni Dönem Ekle</h2>
        @using (Html.BeginForm("DonemEkle", "Admin", FormMethod.Post))
        {
            <div class="form-group">
                <label>Dönem Adı</label>
                @Html.TextBoxFor(m => m.Ad, new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Başlangıç Tarihi</label>
                @Html.TextBoxFor(m => m.BaslangicTarihi, new { @class = "form-control", type = "date" })
            </div>
            <div class="form-group">
                <label>Bitiş Tarihi</label>
                @Html.TextBoxFor(m => m.BitisTarihi, new { @class = "form-control", type = "date" })
            </div>
            <div class="form-group">
                <label>Aktif Mi?</label>
                @Html.CheckBoxFor(m => m.AktifMi)
            </div>
            <button type="submit" class="btn" style="background-color:#0F172A; color:white; margin-top:10px;">Kaydet</button>
            @Html.ActionLink("İptal", "DonemListesi", "Admin", null, new { @class = "btn", style = "background-color:#7F1D1D;color:white;margin-top:10px;" })
        }
    </div>
</div>