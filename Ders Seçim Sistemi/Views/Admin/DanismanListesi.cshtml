@model IEnumerable<Ders_Seçim_Sistemi.Models.Entities.Danisman>

@{
    ViewBag.Title = "Danışman İşlemleri";
}

<div class="container">
    <h2>Danışman İşlemleri</h2>
    @Html.ActionLink("Yeni Danışman Ekle", "DanismanEkle", "Admin", null, new { @class = "btn", style = "background-color: #0F172A; color: white; margin-top: 10px; margin-bottom: 10px;" })
    <table class="table" style="border: 2px solid #0F172A; border-collapse: collapse;">
        <thead>
        <thead style="background-color: #0F172A; color: white;">
            <tr>
                <th>Id</th>
                <th>Ad Soyad</th>
                <th>Email</th>
                <th>Bölüm</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var danisman in Model)
            {
                <tr>
                    <td>@danisman.Id</td>
                    <td>@(danisman.Kullanici != null ? danisman.Kullanici.Ad + " " + danisman.Kullanici.Soyad : "-")</td>
                    <td>@(danisman.Kullanici != null ? danisman.Kullanici.Email : "-")</td>
                    <td>@(danisman.Bolum != null ? danisman.Bolum.Ad : "-")</td>
                    <td>
                        @Html.ActionLink("Güncelle", "DanismanGuncelle", "Admin", new { id = danisman.Id }, new { @class = "btn btn-sm", style = "background-color: #0F172A; color: white;" })
                        @Html.ActionLink("Sil", "DanismanSil", "Admin", new { id = danisman.Id }, new { @class = "btn btn-sm", style = "background-color: #7F1D1D; color: white;" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">@TempData["Hata"]</div>
    }
    @Html.ActionLink("Admin Paneline Dön", "Index", "Admin", null, new { @class = "btn", style = "background-color: #7F1D1D; color: white;" })
</div>