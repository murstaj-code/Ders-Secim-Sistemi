@model Ders_Seçim_Sistemi.Models.Entities.Ders

@{
    ViewBag.Title = "Ders Güncelle";
}

<style>
    .form-kutu {
        border: 4px solid #0F172A;
        border-radius: 12px;
        padding: 30px;
        width: 450px;
        margin: 40px auto;
        background-color: #f7f7f0;
    }

        .form-kutu .form-control {
            border: 2px solid #0F172A;
        }

            .form-kutu .form-control:focus {
                border: 2px solid #0F172A;
                box-shadow: none;
            }
</style>

<div class="container">
    <div class="form-kutu">
        <h2 style="text-align:center;">Ders Güncelle</h2>
        @using (Html.BeginForm("DersGuncelle", "Admin", new { id = Model.Id }, FormMethod.Post))
        {
            <div class="form-group">
                <label>Ders Adı</label>
                <input type="text" name="Ad" class="form-control" value="@Model.Ad" />
            </div>
            <div class="form-group">
                <label>Kredi</label>
                <input type="number" name="Kredi" class="form-control" value="@Model.Kredi" />
            </div>
            <div class="form-group">
                <label>Kontenjan</label>
                <input type="number" name="Kontenjan" class="form-control" value="@Model.Kontenjan" />
            </div>
            <div class="form-group">
                <label>Bölüm</label>
                @Html.DropDownList("BolumId", ViewBag.BolumId as SelectList, "Seçiniz", new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Danışman</label>
                @Html.DropDownList("DanismanId", ViewBag.DanismanId as SelectList, "Seçiniz", new { @class = "form-control" })
            </div>
            <div class="form-group">
                <label>Gün</label>
                <select name="Gun" class="form-control">
                    <option value="">Seçiniz</option>
                    <option value="Pazartesi" @(Model.Gun == "Pazartesi" ? "selected" : "")>Pazartesi</option>
                    <option value="Salı" @(Model.Gun == "Salı" ? "selected" : "")>Salı</option>
                    <option value="Çarşamba" @(Model.Gun == "Çarşamba" ? "selected" : "")>Çarşamba</option>
                    <option value="Perşembe" @(Model.Gun == "Perşembe" ? "selected" : "")>Perşembe</option>
                    <option value="Cuma" @(Model.Gun == "Cuma" ? "selected" : "")>Cuma</option>
                </select>
            </div>
            <div class="form-group">
                <label>Başlangıç Saati</label>
                <input type="time" name="SaatBaslangic" class="form-control" value="@Model.SaatBaslangic" />
            </div>
            <div class="form-group">
                <label>Bitiş Saati</label>
                <input type="time" name="SaatBitis" class="form-control" value="@Model.SaatBitis" />
            </div>
            <button type="submit" class="btn" style="background-color:#0F172A; color:white; margin-top:10px;">Güncelle</button>
            @Html.ActionLink("İptal", "DersListesi", "Admin", null, new { @class = "btn", style = "background-color:#7F1D1D;color:white;margin-top:10px;" })
        }
        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger">@TempData["Hata"]</div>
        }   
    </div>
</div>